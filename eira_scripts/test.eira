sign Cat {
    name: Text,
}

attune Cat {
    spell meow(a: Text) {
        chant ego.name + " @a";
        chant "maaaw :3";
    }
}

mark c = ~Cat with {
    name: "nikki",
};

cast c.meow with "meowed";

spell bark (howmanytimes: Num) {
    
    chant "woof woof";
}

mark _bark = bark;

cast _bark with 1;

mark b=  cast ceil with 2.5;

spell floor(val: Num) {
    chant "this is a floor";
}

cast floor with 2.5;